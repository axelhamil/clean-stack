{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/api": {
      "entry": ["common/**/*.ts", "src/__TESTS__/**/*.test.ts"],
      "project": ["**/*.ts"]
    },
    "apps/app": {
      "entry": ["src/main.tsx", "src/routeTree.gen.ts"],
      "project": ["**/*.ts", "**/*.tsx"]
    },
    "packages/ddd-kit": {
      "project": ["src/**/*.ts"],
      "ignore": ["**/stubs/**"]
    },
    "packages/drizzle": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/test": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignore": ["**/vitest.config.ts"],
  "ignoreDependencies": [
    "tailwindcss",
    "@packages/test",
    "@packages/drizzle",
    "date-fns",
    "lint-staged"
  ],
  "ignoreBinaries": ["vitest"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "off",
    "unresolved": "off",
    "optionalPeerDependencies": "off",
    "exports": "warn",
    "types": "warn",
    "duplicates": "off"
  }
}
