{
  "name": "clean-stack",
  "private": true,
  "version": "1.19.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "type-check": "turbo type-check",
    "check": "biome check .",
    "fix": "biome check --write .",
    "ci:check": "biome ci .",
    "check:duplication": "jscpd ./packages ./apps/api/src ./apps/app/src",
    "check:unused": "knip",
    "db:push": "turbo db:push",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "db:studio": "turbo db:studio",
    "ui:add": "turbo ui:add",
    "dev:docker": "docker compose up --watch",
    "bootstrap": "bash scripts/bootstrap.sh",
    "clean": "rm -rf node_modules .turbo apps/*/.turbo packages/*/.turbo apps/api/dist apps/app/dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@packages/typescript-config": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "jscpd": "^4.2.3",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "semantic-release": "^25.0.3",
    "turbo": "^2.9.14"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "biome format --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24.15.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "@swc/core",
      "esbuild",
      "sharp"
    ]
  }
}
