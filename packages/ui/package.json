{
  "name": "@packages/ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ui": "pnpm dlx shadcn@latest",
    "type-check": "tsc --noEmit",
    "format": "biome format . --write",
    "lint": "biome lint .",
    "check": "biome check .",
    "fix": "biome check --write .",
    "ui:add": "pnpm dlx shadcn@latest add",
    "ui:fix-imports": "sed -i 's|from \"/src/libs/utils\"|from \"../../libs/utils\"|g; s|from \"/src/hooks/\\([^\"]*\\)\"|from \"../../hooks/\\1\"|g; s|from \"/src/components/ui/\\([^\"]*\\)\"|from \"./\\1\"|g; s|from \"/src/components/lib/utils\"|from \"../../libs/utils\"|g' src/components/ui/*.tsx"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./styles/globals.css": "./src/styles/globals.css",
    "./libs/*": "./src/libs/*",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/ui/*": "./src/components/ui/*.tsx",
    "./index": "./src/index.ts"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "lucide-react-native": ">=0.400",
    "nativewind": "^4",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.71.1",
    "react-native": ">=0.70",
    "zod": "^4.2.1"
  },
  "peerDependenciesMeta": {
    "@hookform/resolvers": {
      "optional": true
    },
    "lucide-react-native": {
      "optional": true
    },
    "nativewind": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.12.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "^4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@packages/typescript-config": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  }
}
