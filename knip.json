{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/api": {
      "entry": ["src/index.ts", "src/di/container.ts", "common/**/*.ts"],
      "project": ["**/*.ts"]
    },
    "apps/app": {
      "entry": ["src/routeTree.gen.ts"],
      "project": ["**/*.ts", "**/*.tsx"]
    },
    "packages/ddd-kit": {
      "project": ["src/**/*.ts"],
      "ignore": ["**/stubs/**"]
    },
    "packages/drizzle": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/test": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@packages/test",
    "@packages/drizzle",
    "@packages/ddd-kit",
    "@packages/typescript-config",
    "lint-staged",
    "tailwindcss"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "off",
    "unresolved": "off",
    "optionalPeerDependencies": "off",
    "exports": "warn",
    "types": "warn",
    "duplicates": "off"
  }
}
