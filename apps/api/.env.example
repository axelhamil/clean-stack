NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/clean_stack
CORS_ORIGIN=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
APP_URL=http://localhost:5173

# Resend (optional in dev, required in prod)
# Template IDs live in apps/api/src/adapters/services/email.service.ts (TEMPLATE_IDS)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# S3-compatible storage (R2 in prod, SeaweedFS in dev — opt-in via compose profile `storage`)
# Dev: `docker compose --profile storage up -d`. Host port is assigned randomly by Docker;
# find it with `docker compose port seaweedfs 8333`. Inside compose network, use `seaweedfs:8333`.
# SeaweedFS accepts any credentials by default (no auth) — placeholders below are fine for dev.
S3_ENDPOINT=http://localhost:8333
S3_REGION=auto
S3_BUCKET=clean-stack
S3_ACCESS_KEY=dev
S3_SECRET_KEY=dev
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:8333/clean-stack

# Storage limits (defaults shown; override per environment)
STORAGE_MAX_UPLOAD_BYTES=52428800
STORAGE_PRESIGN_TTL_MIN_SECONDS=60
STORAGE_PRESIGN_TTL_MAX_SECONDS=3600

# Internal endpoints (cron sweeps, etc.)
# HMAC signing key — never travels on the wire (used to sign + verify requests).
# Required in prod, min 32 chars. Generate: openssl rand -hex 32
INTERNAL_SIGNING_KEY=
# Comma-separated layers — "signature" alone, or "signature,private-network"
# on infra with a private mesh (Railway, Fly). "signature" is mandatory in prod.
INTERNAL_AUTH_LAYERS=signature

# RGPD / CCPA
RGPD_GRACE_PERIOD_DAYS=7
RGPD_EXPORT_RATE_LIMIT_HOURS=24
RGPD_SWEEP_BATCH_SIZE=50
