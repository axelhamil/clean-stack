{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "root": true,
  "assist": {
    "actions": {
      "source": { "organizeImports": "on" }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "error",
        "noUndeclaredVariables": "error",
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": "error",
        "noUnreachable": "warn",
        "noSwitchDeclarations": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noEmptyInterface": "warn",
        "noRedundantUseStrict": "warn",
        "noAssignInExpressions": "warn",
        "noDoubleEquals": "warn",
        "noPrototypeBuiltins": "warn",
        "noConstEnum": "off",
        "noConsole": {
          "level": "warn",
          "options": { "allow": ["log", "error", "warn", "info"] }
        },
        "noImportCycles": "error",
        "noUnusedExpressions": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useConst": "warn",
        "useTemplate": "warn",
        "useImportType": "warn",
        "useExportType": "warn",
        "noParameterAssign": "warn",
        "useShorthandAssign": "warn",
        "useAsConstAssertion": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "noUnusedTemplateLiteral": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error",
        "useConsistentArrayType": {
          "level": "warn",
          "options": { "syntax": "shorthand" }
        }
      },
      "complexity": {
        "noForEach": "off",
        "noBannedTypes": "warn",
        "noStaticOnlyClass": "warn",
        "noUselessConstructor": "warn",
        "noUselessFragments": "warn",
        "noThisInStatic": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn",
        "noDangerouslySetInnerHtmlWithChildren": "error",
        "noBlankTarget": "warn"
      },
      "performance": {
        "noDelete": "off",
        "noAccumulatingSpread": "warn"
      },
      "a11y": {
        "useAltText": "warn",
        "useKeyWithClickEvents": "warn",
        "useValidAnchor": "warn",
        "noAccessKey": "warn",
        "useButtonType": "warn",
        "useMediaCaption": "warn",
        "noHeaderScope": "warn",
        "noPositiveTabindex": "warn",
        "useIframeTitle": "warn",
        "noRedundantRoles": "warn",
        "useAriaPropsForRole": "warn",
        "useAnchorContent": "warn",
        "noSvgWithoutTitle": "warn",
        "noAutofocus": "off",
        "useHeadingContent": "warn"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf",
    "includes": [
      "**",
      "!**/node_modules/**",
      "!**/.next/**",
      "!**/dist/**",
      "!**/build/**",
      "!**/routeTree.gen.ts"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "json": {
    "parser": {
      "allowComments": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "allowWrongLineComments": true,
      "tailwindDirectives": true
    },
    "formatter": {
      "enabled": true
    }
  },
  "overrides": [
    {
      "includes": ["packages/ui/src/components/ui/**"],
      "linter": {
        "rules": {
          "a11y": {
            "useKeyWithClickEvents": "off",
            "useAriaPropsForRole": "off",
            "noRedundantRoles": "off",
            "useFocusableInteractive": "off",
            "useSemanticElements": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noDocumentCookie": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/drizzle/src/seeds/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["**/routeTree.gen.ts"],
      "linter": { "enabled": false },
      "assist": { "enabled": false }
    },
    {
      "includes": ["packages/drizzle/migrations/**"],
      "linter": { "enabled": false },
      "formatter": { "enabled": false },
      "assist": { "enabled": false }
    }
  ],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
