{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    "apps/api": {
      "entry": [
        "src/container.ts",
        "src/shared/middleware/*.ts",
        "src/shared/internal-routes/internal-fetch.ts",
        "src/modules/*/module.ts",
        "src/modules/*/routes.ts",
        "src/modules/*/internal.routes.ts"
      ],
      "project": ["**/*.ts"],
      "ignoreDependencies": ["pino-pretty"]
    },
    "apps/app": {
      "entry": [
        "src/shared/api/api-client.ts",
        "src/shared/api/mutations/*.ts",
        "src/shared/api/queries/*.ts"
      ],
      "project": ["**/*.ts", "**/*.tsx"]
    },
    "packages/ddd-kit": {
      "project": ["src/**/*.ts"],
      "ignore": ["**/stubs/**"]
    },
    "packages/drizzle": {
      "project": ["src/**/*.ts"]
    },
    "packages/access-control": {
      "project": ["src/**/*.ts"]
    },
    "packages/ui": {
      "entry": ["src/**/*.tsx", "src/**/*.ts"],
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    },
    "packages/test": {
      "project": ["src/**/*.ts"]
    }
  },
  "ignoreDependencies": [
    "@packages/test",
    "@packages/typescript-config",
    "lint-staged",
    "tailwindcss",
    "conventional-changelog-conventionalcommits"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "unlisted": "off",
    "unresolved": "off",
    "optionalPeerDependencies": "off",
    "exports": "warn",
    "types": "warn",
    "duplicates": "off"
  }
}
