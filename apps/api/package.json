{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts src/migrate.ts --outdir dist --target bun --minify",
    "migrate": "bun src/migrate.ts",
    "start": "bun dist/migrate.js && bun dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch --pass-with-no-tests",
    "test:coverage": "bun test --coverage --pass-with-no-tests"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@better-auth/passkey": "^1.6.11",
    "@better-auth/utils": "^0.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@packages/access-control": "workspace:*",
    "@packages/ddd-kit": "workspace:*",
    "@packages/drizzle": "workspace:*",
    "@packages/events": "workspace:*",
    "@sentry/bun": "^10.54.0",
    "@simplewebauthn/server": "^13.3.0",
    "better-auth": "^1.6.11",
    "hono": "^4.12.22",
    "hono-pino": "^0.10.3",
    "inwire": "^3.0.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@packages/test": "workspace:*",
    "@packages/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
