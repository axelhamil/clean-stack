NODE_ENV=development
PORT=3000

# REQUIRED IN PROD — Railway Postgres add-on injects this via ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/clean_stack

# REQUIRED IN PROD — comma-separated origins (e.g. https://app.example.com)
CORS_ORIGIN=http://localhost:5173

# REQUIRED IN PROD — public api URL (e.g. https://api.example.com)
BETTER_AUTH_URL=http://localhost:3000

# REQUIRED IN PROD — generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# REQUIRED IN PROD — public app URL (used in email links)
APP_URL=http://localhost:5173

# Resend — REQUIRED IN PROD (live key + verified domain SPF+DKIM+DMARC, EU region)
# Template IDs live in apps/api/src/adapters/services/email.service.ts (TEMPLATE_IDS)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# S3-compatible storage — REQUIRED IN PROD (Cloudflare R2 default — see docs/DEPLOY-RAILWAY.md)
# Dev: SeaweedFS via `docker compose --profile storage up -d` (host port 8333).
# Prod R2 example:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_BUCKET=clean-stack
#   S3_ACCESS_KEY=<r2-access-key>
#   S3_SECRET_KEY=<r2-secret-key>
#   S3_FORCE_PATH_STYLE=false
#   S3_PUBLIC_URL=https://<bucket>.<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=http://localhost:8333
S3_REGION=auto
S3_BUCKET=clean-stack
S3_ACCESS_KEY=dev
S3_SECRET_KEY=dev
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:8333/clean-stack

# Storage limits (defaults shown; override per environment)
STORAGE_MAX_UPLOAD_BYTES=52428800
STORAGE_PRESIGN_TTL_MIN_SECONDS=60
STORAGE_PRESIGN_TTL_MAX_SECONDS=3600

# Internal endpoints (cron sweeps, etc.)
# REQUIRED IN PROD — HMAC signing key, min 32 chars. Generate: openssl rand -hex 32
INTERNAL_SIGNING_KEY=
# REQUIRED IN PROD — "signature" alone, or "signature,private-network" on infra with a private mesh.
INTERNAL_AUTH_LAYERS=signature

# RGPD / CCPA
RGPD_GRACE_PERIOD_DAYS=7
RGPD_EXPORT_RATE_LIMIT_HOURS=24
RGPD_SWEEP_BATCH_SIZE=50

# REQUIRED IN PROD — webhook outbound delivery, 64 hex chars (32 bytes). Generate: openssl rand -hex 32
WEBHOOK_MASTER_KEY=

# Audit log tamper-evidence — leave off until SOC2 audit demands hash chain.
AUDIT_TAMPER_EVIDENCE=false

# Retention sweeps (Phase 0.6)
OUTBOX_RETENTION_DAYS=7
AUDIT_LOG_OPERATIONAL_RETENTION_DAYS=90
AUDIT_LOG_COMPLIANCE_RETENTION_DAYS=365
WEBHOOK_DELIVERY_RETENTION_DAYS=30

# Health probes — REQUIRED IN PROD (injected at CI build via .github/workflows/deploy.yml).
GIT_SHA=
BUILD_TIME=
# Grace window after SIGTERM: /readyz flips to 503 instantly, in-flight requests drain for N ms before workers stop.
SHUTDOWN_GRACE_PERIOD_MS=15000

# Sentry — REQUIRED IN PROD (EU residency: use *.eu.sentry.io DSN). Empty DSN = NoOp.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
# Traces deferred (Phase D.1 with OTel). Keep 0 until then.
SENTRY_TRACES_SAMPLE_RATE=0

# REQUIRED IN PROD on the `cron` Railway service only (e.g. https://api.<domain> or ${{api.RAILWAY_PUBLIC_DOMAIN}}).
API_URL=
