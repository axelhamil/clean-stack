NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/clean_stack
CORS_ORIGIN=http://localhost:5173
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
APP_URL=http://localhost:5173

# Resend (optional in dev, required in prod)
# Template IDs live in apps/api/src/adapters/services/email.service.ts (TEMPLATE_IDS)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# S3-compatible storage (R2 in prod, SeaweedFS in dev — opt-in via compose profile `storage`)
# Dev: `docker compose --profile storage up -d`. Host port is pinned to 8333 in compose.
# Inside the compose network, use `seaweedfs:8333` (overridden by env in the `api` service).
# SeaweedFS accepts any credentials by default (no auth) — placeholders below are fine for dev.
S3_ENDPOINT=http://localhost:8333
S3_REGION=auto
S3_BUCKET=clean-stack
S3_ACCESS_KEY=dev
S3_SECRET_KEY=dev
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:8333/clean-stack

# Storage limits (defaults shown; override per environment)
STORAGE_MAX_UPLOAD_BYTES=52428800
STORAGE_PRESIGN_TTL_MIN_SECONDS=60
STORAGE_PRESIGN_TTL_MAX_SECONDS=3600

# Internal endpoints (cron sweeps, etc.)
# HMAC signing key — never travels on the wire (used to sign + verify requests).
# Required in prod, min 32 chars. Generate: openssl rand -hex 32
INTERNAL_SIGNING_KEY=
# Comma-separated layers — "signature" alone, or "signature,private-network"
# on infra with a private mesh (Railway, Fly). "signature" is mandatory in prod.
INTERNAL_AUTH_LAYERS=signature

# RGPD / CCPA
RGPD_GRACE_PERIOD_DAYS=7
RGPD_EXPORT_RATE_LIMIT_HOURS=24
RGPD_SWEEP_BATCH_SIZE=50

# Webhook outbound delivery — encrypts per-endpoint secrets at rest (XChaCha20-Poly1305 + HKDF per org).
# Required in prod, 64 hex chars (32 bytes). Generate: openssl rand -hex 32
WEBHOOK_MASTER_KEY=

# Audit log tamper-evidence — leave off until SOC2 audit demands hash chain.
# When "true", AuditEventSubscriber computes prev_hash/hash chain on insert (deferred impl).
AUDIT_TAMPER_EVIDENCE=false

# Retention sweeps (Phase 0.6)
OUTBOX_RETENTION_DAYS=7
AUDIT_LOG_OPERATIONAL_RETENTION_DAYS=90
AUDIT_LOG_COMPLIANCE_RETENTION_DAYS=365
WEBHOOK_DELIVERY_RETENTION_DAYS=30

# Health probes (Phase 0.2) — injected at CI build for release tracking + /livez payload.
GIT_SHA=
BUILD_TIME=
# Grace window after SIGTERM: /readyz flips to 503 instantly, in-flight requests drain for N ms before workers stop.
SHUTDOWN_GRACE_PERIOD_MS=15000

# Sentry (Phase 0.4) — error tracking. Empty DSN = NoOp (no telemetry leaves the host).
# EU residency: use *.eu.sentry.io DSN.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
# Traces deferred (Phase D.1 with OTel). Keep 0 until then.
SENTRY_TRACES_SAMPLE_RATE=0
