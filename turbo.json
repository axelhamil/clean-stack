{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "biome.json",
    "pnpm-workspace.yaml",
    "**/.env",
    "**/.env.local",
    "**/.env.production"
  ],
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "DATABASE_URL",
    "CORS_ORIGIN",
    "APP_URL",
    "BETTER_AUTH_*",
    "RESEND_*",
    "INTERNAL_*",
    "RGPD_*",
    "S3_*",
    "STORAGE_*",
    "VITE_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "with": ["type-check"],
      "inputs": [
        "src/**",
        "common/**",
        "package.json",
        "tsconfig*.json",
        "tsup.config.ts",
        "vite.config.ts",
        "drizzle.config.ts"
      ],
      "outputs": ["dist/**", "build/**", "!dist/**/*.map"],
      "env": ["DATABASE_URL"],
      "passThroughEnv": ["DATABASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "env": ["DATABASE_URL"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "common/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/__TESTS__/**",
        "package.json",
        "tsconfig*.json",
        "vitest.config.*"
      ],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true,
      "interruptible": true
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "common/**", "package.json", "tsconfig*.json"],
      "outputs": []
    },
    "format": { "outputs": [] },
    "lint": { "outputs": [] },
    "db:generate": { "cache": false, "env": ["DATABASE_URL"] },
    "db:push": { "cache": false, "env": ["DATABASE_URL"] },
    "db:seed": { "cache": false, "env": ["DATABASE_URL"] },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "interruptible": true,
      "env": ["DATABASE_URL"]
    },
    "db:migrate": {
      "dependsOn": ["db:generate"],
      "cache": false,
      "outputs": ["drizzle/migrations/**"],
      "env": ["DATABASE_URL"]
    },
    "ui:add": { "cache": false, "interactive": true }
  }
}
