{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "test:watch": "bun test --watch --pass-with-no-tests",
    "test:coverage": "bun test --coverage --pass-with-no-tests"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@packages/ddd-kit": "workspace:*",
    "@packages/drizzle": "workspace:*",
    "hono": "^4.12.15",
    "inwire": "^2.1.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@packages/test": "workspace:*",
    "@packages/typescript-config": "workspace:*",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
